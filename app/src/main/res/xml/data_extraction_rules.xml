<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include shared preferences -->
        <include domain="sharedpref" path="."/>
        <!-- Include files -->
        <include domain="file" path="."/>
        <!-- Exclude cache -->
        <exclude domain="file" path="cache"/>
    </cloud-backup>
    <device-transfer>
        <!-- Include shared preferences -->
        <include domain="sharedpref" path="."/>
        <!-- Include files -->
        <include domain="file" path="."/>
        <!-- Exclude cache -->
        <exclude domain="file" path="cache"/>
    </device-transfer>
</data-extraction-rules>